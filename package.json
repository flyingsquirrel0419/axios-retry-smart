{
  "name": "axios-retry-smart",
  "version": "1.0.0",
  "description": "Smart Axios retries with backoff, jitter, circuit breaking, and basic observability.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "examples",
    "benchmarks",
    "docs",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage .vitest",
    "lint": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "bench": "tsx benchmarks/comparison.ts"
  },
  "peerDependencies": {
    "axios": ">=1.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "axios": "^1.8.4",
    "nock": "^14.0.10",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "axios",
    "retry",
    "circuit-breaker",
    "backoff",
    "jitter",
    "typescript"
  ]
}
